# ─── O-229 Marketplace — Root .gitignore ────────────────

# Environment files (contain secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker volumes data (never commit)
postgres_data/
redis_data/
meilisearch_data/
minio_data/

# Logs
*.log
