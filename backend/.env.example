APP_NAME="O-229 Marketplace"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL via Docker) ────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=o229_marketplace
DB_USERNAME=o229_user
DB_PASSWORD=o229_password

# ─── Session ─────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Services ────────────────────────────────────────
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=redis

# ─── Cache ───────────────────────────────────────────
CACHE_STORE=redis

# ─── Redis ───────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret_password
REDIS_PORT=6379

# ─── Meilisearch ─────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=o229_meili_master_key

# ─── Sanctum ─────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ─── Mail ────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@o-229.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Laravel Reverb (WebSockets) ─────────────────────
REVERB_APP_ID=876519
REVERB_APP_KEY=0uj3q8mb9ctvduekysto
REVERB_APP_SECRET=eidtxwdtsrxcugcbz7su
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── FedaPay (Paiement) ─────────────────────────────
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxx
FEDAPAY_SECRET_KEY=sk_sandbox_xxxx
FEDAPAY_ENVIRONMENT=sandbox

# ─── MinIO (Object Storage) ─────────────────────────
MINIO_KEY=o229_minio_user
MINIO_SECRET=o229_minio_password
MINIO_REGION=us-east-1
MINIO_BUCKET=o229_marketplace
MINIO_ENDPOINT=http://minio:9000

# ─── Tracking ───────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# ─── System Health Alerts ───────────────────────────
DISCORD_ERROR_WEBHOOK_URL=
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# ─── WhatsApp (Evolution API) ───────────────────────
WA_API_URL=http://evolution_api:8080
WA_API_KEY=o229_wa_secret_key
WA_INSTANCE_NAME=O229_MAIN
